@{
    ViewData["Title"] = "Orders";
    List<Order> orders = (List<Order>)ViewData["allCustomerOrders"];
}

<link rel="stylesheet" href="~/css/NavBarStyle.css" />

<style>
    body {
        font-family: 'Poppins', 'Segoe UI', sans-serif;
        background-color: #0f172a;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    .main {
        padding: 50px 20px;
        max-width: 1300px;
        margin: auto;
    }

    /* ---------- HEADER ---------- */
    .page-title {
        font-size: 52px;
        font-weight: 800;
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
    }

    .orders-count {
        font-size: 20px;
        color: #94a3b8;
    }

    /* ---------- GRID ---------- */
    .orders-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
        gap: 24px;
        margin-top: 40px;
    }

    /* ---------- CARD ---------- */
    .order-card {
        background: linear-gradient(145deg, #1e293b, #0f172a);
        border-radius: 18px;
        padding: 28px;
        border: 1px solid #334155;
        transition: all 0.35s ease;
    }

    .order-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 25px 45px rgba(0, 0, 0, 0.6);
        border-color: #fbbf24;
    }

    /* ---------- CARD HEADER ---------- */
    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 14px;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }

    .order-id {
        font-size: 13px;
        color: #94a3b8;
        font-weight: 600;
        letter-spacing: 1px;
    }

    /* ---------- STATUS ---------- */
    .status-pill {
        padding: 8px 18px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .status-pending {
        background: #64748b;
        color: #0f172a;
    }

    .status-processing {
        background: #fbbf24;
        color: #0f172a;
    }

    .status-shipped {
        background: #10b981;
        color: #ffffff;
    }

    .status-delivered {
        background: #22c55e;
        color: #ffffff;
    }

    .status-cancelled {
        background: #ef4444;
        color: #ffffff;
    }

    /* ---------- BODY ---------- */
    .order-body {
        display: grid;
        gap: 16px;
    }

    .order-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-label {
        font-size: 12px;
        color: #94a3b8;
        text-transform: uppercase;
        font-weight: 600;
    }

    .order-value {
        font-size: 15px;
        color: #e5e7eb;
        font-weight: 600;
    }

    .order-amount {
        font-size: 30px;
        font-weight: 800;
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ---------- ADDRESS ---------- */
    .order-address {
        background: rgba(30, 41, 59, 0.8);
        padding: 16px;
        border-radius: 14px;
        border: 1px solid #334155;
    }

    .address-label {
        font-size: 11px;
        color: #fbbf24;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 6px;
    }

    .address-text {
        font-size: 14px;
        color: #cbd5f5;
        line-height: 1.6;
    }

    /* ---------- ACTIONS ---------- */
    .order-action {
        display: flex;
        gap: 16px;
        margin-top: 24px;
    }

    .action-btn {
        flex: 1;
        padding: 14px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
        color: #0f172a;
    }

    .btn-danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #ffffff;
    }

    .action-btn:hover {
        transform: translateY(-2px);
    }

    .action-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
    }

    /* ---------- EMPTY STATE ---------- */
    .no-orders-container {
        text-align: center;
        padding: 120px 20px;
    }

    .no-orders-icon {
        font-size: 90px;
        opacity: 0.3;
        margin-bottom: 20px;
    }

    .no-orders-title {
        font-size: 30px;
        color: #e5e7eb;
        font-weight: 700;
    }

    .no-orders-text {
        color: #94a3b8;
        margin-top: 10px;
        font-size: 18px;
    }

    /* ---------- RESPONSIVE ---------- */
    @@media
    (max-width: 768px) {
        .orders-grid {
            grid-template-columns: 1fr;
        }

        .order-action {
            flex-direction: column;
        }

        .page-title {
            font-size: 36px;
        }
    }
</style>

<div class="main">
    <h1 class="page-title">Order History</h1>
    <p class="orders-count">Total Orders: @(orders?.Count ?? 0)</p>

    @if (orders != null && orders.Count > 0)
    {
        <div class="orders-grid">
            @foreach (var order in orders)
            {
                <div class="order-card">
                    <div class="order-header">
                        <span class="order-id">Order #@order.OrderId</span>
                        <span class="status-pill status-@order.status.ToLower()">
                            @order.status
                        </span>
                    </div>

                    <div class="order-body">
                        <div class="order-row">
                            <span class="order-label">Total Amount</span>
                            <span class="order-amount">₹@order.TotalAmount.ToString("N0")</span>
                        </div>

                        <div class="order-row">
                            <span class="order-label">Order Date</span>
                            <span class="order-value">@order.orderDate.ToString("MMM dd, yyyy")</span>
                        </div>

                        <div class="order-row">
                            <span class="order-label">Shipping Date</span>
                            <span class="order-value">
                                @(order.ShippingDate.HasValue
                                    ? order.ShippingDate.Value.ToString("MMM dd, yyyy")
                                    : "Not Shipped Yet")
                            </span>
                        </div>

                        <div class="order-address">
                            <div class="address-label">Delivery Address</div>
                            <div class="address-text">@order.Address</div>
                        </div>

                       

                            <div class="order-action">
                                <a href="/OrderProcessing/OrderItemDetails/@order.OrderId">
                                    <button class="action-btn btn-primary">View Items</button>
                                </a>

                                @{
                                    bool canCancel =
                                    !string.IsNullOrEmpty(order.status) &&
                                    order.status.Equals("Pending", StringComparison.OrdinalIgnoreCase);
                                }

                                @if (canCancel)
                                {
                                    <form asp-action="CancelOrder" asp-controller="OrderProcessing" method="post"
                                          onsubmit="return confirm('Are you sure you want to cancel this order?');">
                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                        <button type="submit" class="action-btn btn-danger">
                                            Cancel Order
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="action-btn btn-danger" disabled>
                                        Cancel Order
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
               
            }
        </div>
    }
    else
    {
        <div class="no-orders-container">
            <div class="no-orders-icon">🛍️</div>
            <div class="no-orders-title">No Orders Found</div>
            <div class="no-orders-text">
                Your order history will appear here once you make a purchase
            </div>
        </div>
    }
</div>